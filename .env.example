# ===== REQUIRED =====
# Get from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# ===== OPTIONAL (feature won't work without these, rest of bot is fine) =====

# Needed for /imgurl command - get free key from https://api.imgbb.com/
IMGBB_API_KEY=

# Needed for /removebg command - get free key from https://www.remove.bg/api
REMOVEBG_API_KEY=

# Needed for /ocr command - get free key from https://ocr.space/ocrapi
# If left empty, falls back to a limited shared demo key
OCR_API_KEY=

